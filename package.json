{
  "name": "slop-eval-cli",
  "version": "0.1.2",
  "description": "Scores AI-generated UI for genericness (\"slop\") using an LLM-judge rubric. Composable RuleSource plugin architecture designed to complement deterministic rule catalogs, not replace them.",
  "keywords": [
    "ai",
    "ui",
    "slop",
    "eval",
    "ci",
    "quality-gate",
    "llm-judge",
    "design"
  ],
  "homepage": "https://github.com/RudrenduPaul/slop-eval#readme",
  "bugs": {
    "url": "https://github.com/RudrenduPaul/slop-eval/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RudrenduPaul/slop-eval.git"
  },
  "license": "Apache-2.0",
  "author": "",
  "bin": {
    "slop-eval": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist",
    "src/rubric",
    "action",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
